# === AI (Gemini, gratis) ===
GEMINI_API_KEY=your_gemini_api_key_here
# Model klasifikasi (opsional, default gemini-2.5-flash)
GEMINI_MODEL=gemini-2.5-flash

# === Telegram Bot ===
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# === Dashboard ===
# URL publik dashboard (dicantumkan di laporan Telegram). Isi setelah deploy.
DASHBOARD_URL=

# === Sumber Scraper (multi-sumber) ===
# Sumber yang diaktifkan, dipisah koma. Pilihan: olx, threads, facebook
ENABLED_SCRAPERS=olx,threads,facebook
# Maksimum item per sumber per run
SCRAPER_LIMIT=25

# Threads (Meta) — kata kunci niat beli/jual yang dicari (dipisah koma)
THREADS_KEYWORDS=dicari rumah sidoarjo,cari rumah surabaya,butuh rumah sidoarjo,wtb rumah surabaya

# Facebook Group (sumber PEMBELI terkaya) — butuh sesi login Harvey sendiri.
# FB_COOKIE: salin header Cookie dari browser yang sudah login (mbasic.facebook.com).
# FB_GROUP_IDS: ID grup jual-beli properti yang diikuti, dipisah koma.
# Kosongkan keduanya untuk melewati scraper Facebook.
FB_COOKIE=
FB_GROUP_IDS=

# === Opsi developer ===
# Set 1 hanya untuk testing lokal agar memakai data contoh saat scraper diblokir.
# WAJIB 0 (atau kosong) di produksi supaya data palsu tidak masuk database.
USE_MOCK_DATA=0

# === Google Sheets (opsional, untuk backup/akses dari mana saja) ===
GOOGLE_CREDENTIALS_FILE=credentials.json
GOOGLE_SHEET_URL=
