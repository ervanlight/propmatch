# === AI (Claude Haiku 4.5, berbayar tapi sangat murah ~$0.0016/klasifikasi) ===
ANTHROPIC_API_KEY=your_anthropic_api_key_here
# Model klasifikasi (opsional, default claude-haiku-4-5)
CLAUDE_MODEL=claude-haiku-4-5
# Jeda antar panggilan klasifikasi (detik). Default 0 -- tier berbayar Claude
# punya limit per-menit yang longgar. Naikkan hanya jika sering kena error 429.
CLAUDE_CALL_DELAY_SECONDS=0

# === Telegram Bot ===
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# === Database (Turso -- libSQL remote, satu-satunya sumber data) ===
# Dipakai bersama oleh: laptop (main.py/bot.py lokal), GitHub Actions
# (scraping), dan semua serverless function di api/ (Vercel). Dapatkan dari
# dashboard Turso: buka database -> tombol "Connect".
TURSO_DATABASE_URL=libsql://your-db-name.turso.io
TURSO_AUTH_TOKEN=

# === Trigger GitHub Actions dari dashboard (tombol "Jalankan Scraping") ===
# HANYA dipakai di environment Vercel, bukan lokal. GITHUB_TOKEN = personal
# access token dengan scope repo+workflow. GITHUB_REPO = "owner/repo".
GITHUB_TOKEN=
GITHUB_REPO=

# === Dashboard ===
# URL publik dashboard (dicantumkan di laporan Telegram). Isi setelah deploy.
DASHBOARD_URL=
# Login dashboard (HTTP Basic Auth) -- WAJIB diisi di Vercel project settings,
# bukan dipakai lokal. Dashboard berisi kontak pribadi penjual/pembeli hasil
# scraping sehingga tidak boleh jadi URL publik tanpa login (lihat api/dashboard.py).
DASHBOARD_USER=harvey
DASHBOARD_PASSWORD=

# === Sumber Scraper (multi-sumber) ===
# Sumber yang diaktifkan, dipisah koma. Pilihan: olx, threads, facebook
ENABLED_SCRAPERS=olx,threads,facebook
# Maksimum item per sumber per run (dinaikkan dari 25 -> 100 setelah pindah
# ke Claude Haiku; biaya klasifikasi tetap murah)
SCRAPER_LIMIT=100

# Threads (Meta) — kata kunci pencarian (dipisah koma), khusus RUMAH jual-beli
# (bukan sewa/kos/ruko/tanah/apartemen, lihat classifier/claude_classifier.py).
# PENDEK lebih efektif daripada frasa panjang & spesifik (terbukti lewat
# pengujian live).
THREADS_KEYWORDS=rumah sidoarjo,rumah surabaya,jual rumah surabaya,cari rumah surabaya,dijual rumah sidoarjo,dicari rumah sidoarjo,jual beli rumah surabaya

# Facebook Group (sumber PEMBELI terkaya) — TIDAK di-scrape otomatis (alasan
# privasi, lihat scraper/facebook_scraper.py). Forward listing menarik secara
# manual ke bot Telegram. Daftar grup di config.py FB_GROUPS hanya untuk
# ditampilkan sebagai link cepat di /help bot.

# === Opsi developer ===
# Set 1 hanya untuk testing lokal agar memakai data contoh saat scraper diblokir.
# WAJIB 0 (atau kosong) di produksi supaya data palsu tidak masuk database.
USE_MOCK_DATA=0

# landing.html + api/submit-lead.py menulis LANGSUNG ke Turso di atas -- tidak
# ada konfigurasi tambahan yang diperlukan untuk landing page.
