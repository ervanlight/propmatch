{
  "version": 2,
  "builds": [
    { "src": "api/telegram.py", "use": "@vercel/python" },
    { "src": "api/submit-lead.py", "use": "@vercel/python" },
    { "src": "api/dashboard.py", "use": "@vercel/python" },
    { "src": "api/match-run.py", "use": "@vercel/python" },
    { "src": "api/parse-text.py", "use": "@vercel/python" },
    { "src": "api/update-status.py", "use": "@vercel/python" },
    { "src": "api/trigger-scrape.py", "use": "@vercel/python" },
    { "src": "api/scrape-status.py", "use": "@vercel/python" },
    { "src": "api/sync-sheets.py", "use": "@vercel/python" },
    { "src": "landing.html", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/telegram", "dest": "api/telegram.py" },
    { "src": "/api/submit-lead", "dest": "api/submit-lead.py" },
    { "src": "/api/match-run", "dest": "api/match-run.py" },
    { "src": "/api/parse-text", "dest": "api/parse-text.py" },
    { "src": "/api/update-status", "dest": "api/update-status.py" },
    { "src": "/api/trigger-scrape", "dest": "api/trigger-scrape.py" },
    { "src": "/api/scrape-status", "dest": "api/scrape-status.py" },
    { "src": "/api/sync-sheets", "dest": "api/sync-sheets.py" },
    { "src": "/cari", "dest": "landing.html" },
    { "src": "/jual", "dest": "landing.html" },
    { "src": "/landing", "dest": "landing.html" },
    { "src": "/index.html", "dest": "api/dashboard.py" },
    { "src": "/", "dest": "api/dashboard.py" }
  ]
}
